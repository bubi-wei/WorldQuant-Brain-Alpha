# ============================================================
# WorldQuant Brain credentials
# ============================================================
WQB_USERNAME=freedom8625@163.com
WQB_PASSWORD=btEobfRbuBpu1

# ============================================================
# LLM settings (choose one provider)
# ============================================================
# LLM provider / model string understood by litellm
# Examples:
#   openai/gpt-4o
#   anthropic/claude-3-5-sonnet-20241022
#   deepseek/deepseek-chat
#   ollama/llama3.1
LLM_MODEL=deepseek/deepseek-reasoner

# API keys — only fill in the one you use
OPENAI_API_KEY=sk-52ba22e5fd1c4b629f481273c559e88f
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
# For local models via vLLM / Ollama, leave API key blank

# ============================================================
# Embedding model (sentence-transformers, runs locally)
# ============================================================
EMBED_MODEL=all-MiniLM-L6-v2

# ============================================================
# Storage paths
# ============================================================
CHROMA_PERSIST_DIR=./data/chroma
DUCKDB_PATH=./data/alpha_memory.db

# ============================================================
# WQB simulation settings (defaults match platform requirements)
# ============================================================
WQB_INSTRUMENT_TYPE=EQUITY
WQB_REGION=USA
WQB_DELAY=1
WQB_DECAY=0
WQB_NEUTRALIZATION=SUBINDUSTRY
WQB_TRUNCATION=0.08
WQB_CONCURRENCY=3

# ============================================================
# Alpha qualification thresholds
# ============================================================
QUAL_SHARPE_MIN=1.5
QUAL_FITNESS_MIN=1.0
QUAL_TURNOVER_MIN=0.1
QUAL_TURNOVER_MAX=0.9
QUAL_IC_MEAN_MIN=0.02

# ============================================================
# Generation loop settings
# ============================================================
IDEAS_PER_ROUND=5
VARIANTS_PER_IDEA=3
MAX_ROUNDS=10
NOVELTY_SCORE_MIN=0.3
